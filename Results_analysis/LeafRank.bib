	month = mar,
	year = {2013},
	note = {arXiv: NIHMS150003
ISBN: 1546-1696 (Electronic){\textbackslash}n1087-0156 (Linking)},
	keywords = {Humans, Neoplasms, cnmut, DNA, Bayes Theorem, Genome, High-Throughput Nucleotide Sequencing, Human, Neoplasms: genetics, somatic mutations, Neoplasm, Heterozygote, High-Throughput Nucleotide Sequencing: methods, Neoplasm: analysis, Neoplasm: genetics, Point Mutation, Reproducibility of Results, Sensitivity and Specificity},
	pages = {213--219},
