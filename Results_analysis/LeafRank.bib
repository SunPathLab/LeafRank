	journal = {Nature},
	author = {{The Cancer Genome Atlas Research Network}},
	month = sep,
	year = {2012},
	pages = {519--525},
	file = {PDF:/home/ruping/Zotero/storage/98H8HWPN/The Cancer Genome Atlas Research Network - 2012 - Comprehensive genomic characterization of squamous cell lung cancers.pdf:application/pdf},
}

@article{el_gammal_chromosome_2010,
	title = {Chromosome \textit{8p} {Deletions} and \textit{8q} {Gains} are {Associated} with {Tumor} {Progression} and {Poor} {Prognosis} in {Prostate} {Cancer}},
	volume = {16},
	issn = {1078-0432, 1557-3265},
	url = {https://aacrjournals.org/clincancerres/article/16/1/56/197734/Chromosome-8p-Deletions-and-8q-Gains-are},
	doi = {10.1158/1078-0432.CCR-09-1423},
	abstract = {Purpose: Deletions of 8p and gains of 8q belong to the most frequent cytogenetic alterations in prostate cancer. The target genes of these alterations and their biological significance are unknown. Experimental Design: To determine the relationship between chromosome 8 changes, and prostate cancer phenotype and prognosis, a set of 1.954 fully annotated prostate cancers were analyzed in a tissue microarray format by fluorescence in situ hybridization.
Results: Both 8p deletions and 8q gains increased in number during different stages of prostate cancer progression. 8p deletions/8q gains were found in 26.1\%/4.8\% of 1,239 pT2 cancers, 38.5\%/9.8\% of 379 pT3a cancers, 43.5\%/8.9\% of 237 pT3b cancers, 40.7\%/14.8\% of 27 pT4 cancers, 39.1\%/34.8\% of 23 nodal metastases, 51.9\%/33.3\% of 27 bone metastases, and 45.5\%/59.9\% of 22 hormone refractory cancers (P {\textless} 0.0001 each). Both 8p deletions and 8q gains were also significantly associated with high Gleason grade and with each other (P {\textless} 0.0001 each). In primary tumors, 8p deletions were seen in only 27.3\% of 1,882 cancers without 8q gain but in 57.4\% of 122 tumors with 8q gain (P {\textless} 0.0001). Among cancers treated with radical prostatectomy, 8p deletions (P = 0.003) and 8q gains (P = 0.02) were associated with biochemical tumor recurrence. However, multivariate analysis (including prostate-specific antigen, pT/pN stage, Gleason score, and surgical margin status) did not reveal any statistically independent effect of 8p or 8q alterations on biochemical tumor recurrence.
Conclusions: 8p deletions and 8q gains are relatively rare in early stage prostate cancer but often develop during tumor progression. The prognostic effect does not seem to be strong enough to warrant clinical application. Clin Cancer Res; 16(1); 56–64. ©2010 AACR.},
	language = {en},
	number = {1},
	urldate = {2026-05-11},
	journal = {Clinical Cancer Research},
	author = {El Gammal, Alexander T. and Brüchmann, Michael and Zustin, Jozef and Isbarn, Hendrik and Hellwinkel, Olaf J.C. and Köllermann, Jens and Sauter, Guido and Simon, Ronald and Wilczak, Waldemar and Schwarz, Jörg and Bokemeyer, Carsten and Brümmendorf, Tim H. and Izbicki, Jakob R. and Yekebas, Emre and Fisch, Margit and Huland, Hartwig and Graefen, Markus and Schlomm, Thorsten},
	month = jan,
	year = {2010},
	pages = {56--64},
	file = {PDF:/home/ruping/Zotero/storage/56DUHAPG/El Gammal et al. - 2010 - Chromosome 8p Deletions and 8q Gains are Associated with Tumor Progression and Poor Pr.pdf:application/pdf},
}

