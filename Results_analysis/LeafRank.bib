@article{tang_tracing_2019,
	title = {Tracing {Tumor} {Evolution} in {Sarcoma} {Reveals} {Clonal} {Origin} of {Advanced} {Metastasis}},
	volume = {28},
	issn = {2211-1247},
	url = {https://pmc.ncbi.nlm.nih.gov/articles/PMC6750751/},
	doi = {10.1016/j.celrep.2019.08.029},
	abstract = {Cellular heterogeneity is frequently observed in cancer, but the biological significance of heterogeneous tumor clones is not well defined. Using multicolor reporters and CRISPR-Cas9 barcoding, we trace clonal dynamics in a mouse model of sarcoma. We show that primary tumor growth is associated with a reduction in clonal heterogeneity. Local recurrence of tumors following surgery or radiation therapy is driven by multiple clones. In contrast, advanced metastasis to the lungs is driven by clonal selection of a single metastatic clone (MC). Using RNA sequencing (RNA-seq) and in vivo assays, we identify candidate suppressors of metastasis, namely, Rasd1, Reck, and Aldh1a2. These genes are downregulated in MCs of the primary tumors prior to the formation of metastases. Overexpression of these suppressors of metastasis impair the ability of sarcoma cells to colonize the lungs. Overall, this study reveals clonal dynamics during each step of tumor progression, from initiation to growth, recurrence, and distant metastasis., Tang et al. demonstrate that distinct clonal architecture underlies different stages of tumor progression, from tumor initiation, local recurrence after therapy, to advanced metastasis.,},
	number = {11},
	urldate = {2026-05-17},
	journal = {Cell reports},
	author = {Tang, Yuning J. and Huang, Jianguo and Tsushima, Hidetoshi and Ban, Ga I. and Zhang, Hongyuan and Oristian, Kristianne M. and Puviindran, Vijitha and Williams, Nerissa and Ding, Xiruo and Ou, Jianhong and Jung, Sin-Ho and Lee, Chang-Lung and Jiao, Yiqun and Chen, Benny J. and Kirsch, David G. and Alman, Benjamin A.},
	month = sep,
